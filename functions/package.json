{
  "name": "menere-functions",
  "description": "Cloud Functions for Menere (TTB COLA class/type lookup)",
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "ttb": "node -e \"require('./ttbLookup').lookupColaClassType({productName:process.argv[1]}).then(r=>console.log(JSON.stringify(r,null,2)))\"",
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.0"
  },
  "private": true
}
