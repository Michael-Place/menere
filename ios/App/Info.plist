<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>¡Bacán!</string>
	<!-- V5-Siri: the App Shortcuts phrases use \(.applicationName); a spoken name lets Siri match
	     "Bacán"/"Bacan" cleanly instead of the punctuated display name "¡Bacán!". -->
	<key>CFBundleSpokenName</key>
	<string>Bacan</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Bacán uses the camera to photograph your plants and pets and to scan wine labels and family documents.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Bacán curates your best family photos into an album your Apple TV can use as its screensaver.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Bacán uses your photos so you can browse and add family moments to your journal.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Bacán uses your location to estimate drive times to dinner.</string>
	<key>NSHomeKitUsageDescription</key>
	<string>Bacán connects to your Home accessories — the garage, locks, and sensors — right on your network.</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Bacán syncs with your Apple calendars so the family sees one schedule.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Bacán talks to your family's home devices — shades, speakers, and bridges — on your home Wi-Fi.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_lutron._tcp</string>
		<string>_sonos._tcp</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Sonos control is plain-HTTP UPnP on the LAN (port 1400); allow local-network loads
		     without disabling ATS for internet traffic. -->
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.copoche.menere.firebaseauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<!-- Firebase Phone Auth callback scheme: app-<GOOGLE_APP_ID with ':' -> '-'>.
				     Required by FirebaseAuth PhoneAuthProvider; without it the SDK fatalErrors. -->
				<string>app-1-769612719019-ios-ad91eddc8fa508f7a9a8ee</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.copoche.menere.nest</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<!-- Nest SDM OAuth (P15-C3) callback scheme for ASWebAuthenticationSession. The redirect
				     URI com.copoche.menere.nest:/oauth2redirect must be registered on the Google OAuth
				     client (see Michael's runbook). Mirrors the firebaseauth entry above. -->
				<string>com.copoche.menere.nest</string>
			</array>
		</dict>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
