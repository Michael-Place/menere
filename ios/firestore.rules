rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared wine catalog (cache + moat): any signed-in user may read; signed-in users may
    // create/update entries since the catalog grows from everyone's scans. Tighten later
    // (e.g. route writes through Cloud Functions + App Check) before any public launch.
    match /wines/{wineId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Apple TV device-pairing handshake (P27-T2-C1). A pre-auth tvOS client writes a pending
    // doc keyed by a short code, then polls it for a `customToken` that the `pairAppleTV` Cloud
    // Function (Admin SDK — bypasses these rules) writes after a phone user confirms the code.
    //   - create: unauthenticated TV may create ONLY the pending shape (status "pending", no token).
    //   - read:   allowed (the TV polls for its token before it has an identity). The token is
    //             only as secret as the short-lived 6-char code — acceptable for a private app.
    //   - update/delete: never from a client; only the Cloud Function may mint/attach the token.
    match /tvPairing/{code} {
      allow read: if true;
      allow create: if request.resource.data.status == "pending"
                    && request.resource.data.keys().hasOnly(["status", "createdAt"]);
      allow update, delete: if false;
    }

    // Private per-user data (profile, householdId): only the owner.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Shared household space: bottles + tastings live here; members read/write.
    match /households/{hid} {
      allow read:   if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.auth.uid in request.resource.data.members;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;

      match /{document=**} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(hid)).data.members;
      }
    }
  }
}
